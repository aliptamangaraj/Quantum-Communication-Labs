from qiskit import QuantumCircuit
from qiskit_aer import AerSimulator
from qiskit.quantum_info import Statevector

qc = QuantumCircuit(3,2)

qc.h(0)
qc.cx(0,1)
qc.barrier()

qc.cx(2,0)
qc.h(2)
qc.barrier()

qc.measure(0, 0) 
qc.measure(1, 1)

with qc.if_test((0,1)):
    qc.x(1)

with qc.if_test((1,1)):
    qc.z(1)

qc.barrier()

qc.measure_all()

qc.draw()
